    MOVE "BANK.CODE"      TO CONF-KEY
    MOVE "FNB001"         TO CONF-VALUE
    MOVE "Bank code"      TO CONF-DESC
    WRITE CONF-REC

    MOVE "BANK.ROUTING"   TO CONF-KEY
    MOVE "071000013"      TO CONF-VALUE
    MOVE "Routing number" TO CONF-DESC
    WRITE CONF-REC

    MOVE "RATES.SAVINGS"  TO CONF-KEY
    MOVE "2.50"           TO CONF-VALUE
