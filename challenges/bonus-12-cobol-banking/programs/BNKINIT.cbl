>>SOURCE FORMAT IS FREE
IDENTIFICATION DIVISION.
PROGRAM-ID. BNKINIT.
*> System Initialization and Seed Data
*> Creates/resets all ISAM data files and loads sample data
*> WARNING: Running this clears all existing data

ENVIRONMENT DIVISION.
INPUT-OUTPUT SECTION.
FILE-CONTROL.
    SELECT USERFILE ASSIGN TO "data/USERFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS USER-ID
        FILE STATUS IS WS-USER-STATUS.

    SELECT CUSTFILE ASSIGN TO "data/CUSTFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS CUST-ID
        ALTERNATE RECORD KEY IS CUST-SSN WITH DUPLICATES
        ALTERNATE RECORD KEY IS CUST-LAST-NAME
            WITH DUPLICATES
        FILE STATUS IS WS-CUST-STATUS.

    SELECT ACCTFILE ASSIGN TO "data/ACCTFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS ACCT-ID
        ALTERNATE RECORD KEY IS ACCT-CUST-ID
            WITH DUPLICATES
        FILE STATUS IS WS-ACCT-STATUS.

    SELECT TXNFILE ASSIGN TO "data/TXNFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS TXN-ID
        ALTERNATE RECORD KEY IS TXN-ACCT-ID
            WITH DUPLICATES
        FILE STATUS IS WS-TXN-STATUS.

    SELECT LOANFILE ASSIGN TO "data/LOANFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS LOAN-ID
        ALTERNATE RECORD KEY IS LOAN-CUST-ID
            WITH DUPLICATES
        FILE STATUS IS WS-LOAN-STATUS.

    SELECT AUDITFILE ASSIGN TO "data/AUDITFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS AUDIT-ID
        ALTERNATE RECORD KEY IS AUDIT-DATE-IDX
            WITH DUPLICATES
        FILE STATUS IS WS-AUDIT-STATUS.

    SELECT BATCHFILE ASSIGN TO "data/BATCHFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS BATCH-RUN-ID
        FILE STATUS IS WS-BATCH-STATUS.

    SELECT CONFFILE ASSIGN TO "data/CONFFILE.dat"
        ORGANIZATION IS INDEXED
        ACCESS MODE IS DYNAMIC
        RECORD KEY IS CONF-KEY
        FILE STATUS IS WS-CONF-STATUS.

DATA DIVISION.
FILE SECTION.
FD  USERFILE.
    COPY "copybooks/USERFLD.cpy".
FD  CUSTFILE.
    COPY "copybooks/CUSTFLD.cpy".
FD  ACCTFILE.
    COPY "copybooks/ACCTFLD.cpy".
FD  TXNFILE.
    COPY "copybooks/TXNFLD.cpy".
FD  LOANFILE.
    COPY "copybooks/LOANFLD.cpy".
FD  AUDITFILE.
    COPY "copybooks/AUDITFLD.cpy".
FD  BATCHFILE.
    COPY "copybooks/BATCHFLD.cpy".
FD  CONFFILE.
    COPY "copybooks/CONFFLD.cpy".

WORKING-STORAGE SECTION.
01  WS-USER-STATUS         PIC X(2).
01  WS-CUST-STATUS         PIC X(2).
01  WS-ACCT-STATUS         PIC X(2).
01  WS-TXN-STATUS          PIC X(2).
01  WS-LOAN-STATUS         PIC X(2).
01  WS-AUDIT-STATUS        PIC X(2).
01  WS-BATCH-STATUS        PIC X(2).
01  WS-CONF-STATUS         PIC X(2).

01  WS-CURRENT-DT.
    05  WS-NOW-YEAR        PIC 9(4).
    05  WS-NOW-MONTH       PIC 9(2).
    05  WS-NOW-DAY         PIC 9(2).
    05  WS-NOW-HOUR        PIC 9(2).
    05  WS-NOW-MIN         PIC 9(2).
    05  WS-NOW-SEC         PIC 9(2).
    05  WS-NOW-HSEC        PIC 9(2).
01  WS-DATETIME-STR        PIC X(19).
01  WS-TODAY-STR            PIC 9(8).

*> Password hashing (djb2 variant -- NOT cryptographically
*> secure, see BNKAUTH for details)
01  WS-HASH-INPUT          PIC X(50).
01  WS-HASH-VAL            PIC 9(18) VALUE 0.
01  WS-HASH-CHAR           PIC 9(3).
01  WS-HASH-I              PIC 9(3).
01  WS-HASH-LEN            PIC 9(3).

*> PMT calculation for loan seed
01  WS-PMT-P               PIC S9(11)V99.
01  WS-PMT-R               PIC 9(3)V99.
01  WS-PMT-N               PIC 9(3).
01  WS-PMT-MR              PIC 9V9(10).
01  WS-PMT-PN              PIC 9(15)V9(6).
01  WS-PMT-RESULT          PIC S9(9)V99.

*> Maturity date calculation
01  WS-MAT-YEAR            PIC 9(4).
01  WS-MAT-MONTH           PIC 9(2).
01  WS-MAT-DAY             PIC 9(2).
01  WS-MATURITY-DATE       PIC 9(8).
01  WS-NEXT-PMT-DATE       PIC 9(8).

PROCEDURE DIVISION.
MAIN-PARA.
    PERFORM INIT-SYSTEM.
    STOP RUN.

*> -------------------------------------------------------
*> INIT-SYSTEM: Main initialization entry point
*> -------------------------------------------------------
INIT-SYSTEM.
    DISPLAY "Initializing system..."

    PERFORM CREATE-FILES
    PERFORM SEED-CONFIG
    PERFORM SEED-USERS
    PERFORM SEED-CUSTOMERS
    PERFORM SEED-ACCOUNTS
    PERFORM SEED-TRANSACTIONS
    PERFORM SEED-LOANS

    DISPLAY " "
    DISPLAY "Initialization complete."
    DISPLAY " "
    DISPLAY "Default login:"
    DISPLAY "  User: admin"
    DISPLAY "  Password: admin123".

*> -------------------------------------------------------
*> CREATE-FILES: Create/reset all data files
*> -------------------------------------------------------
CREATE-FILES.
    OPEN OUTPUT USERFILE
    CLOSE USERFILE
    OPEN OUTPUT CUSTFILE
    CLOSE CUSTFILE
    OPEN OUTPUT ACCTFILE
    CLOSE ACCTFILE
    OPEN OUTPUT TXNFILE
    CLOSE TXNFILE
    OPEN OUTPUT LOANFILE
    CLOSE LOANFILE
    OPEN OUTPUT AUDITFILE
    CLOSE AUDITFILE
    OPEN OUTPUT BATCHFILE
    CLOSE BATCHFILE
    OPEN OUTPUT CONFFILE
    CLOSE CONFFILE.

*> -------------------------------------------------------
*> SEED-CONFIG: System configuration
*> -------------------------------------------------------
SEED-CONFIG.
    DISPLAY "  Setting up configuration..."
