# Normalize line endings
# All text files get LF in the repo; checkout behavior follows eol= rules below
* text=auto eol=lf

# Shell scripts must always check out with LF regardless of core.autocrlf
*.sh  text eol=lf

# PowerShell scripts work correctly with CRLF on Windows
*.ps1 text eol=crlf

# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union

.github/workflows/*.lock.yml linguist-generated=true merge=ours