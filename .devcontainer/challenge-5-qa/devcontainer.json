{
	"name": "Challenge 5 - QA",
	"image": "mcr.microsoft.com/devcontainers/dotnet:dev-10.0-noble",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-dotnettools.csharp",
				"ms-dotnettools.csdevkit",
				"ms-playwright.playwright",
				"ryanluker.vscode-coverage-gutters",
				"humao.rest-client"
			]
		}
	},
	"postCreateCommand": "bash scripts/setup-challenge.sh challenge-5-qa && dotnet tool install --global Microsoft.Playwright.CLI && npm install -g @playwright/test",
	"remoteUser": "vscode"
}
