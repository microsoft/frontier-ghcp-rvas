{
	"name": "Bonus 1 - Copilot SDK",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu",
	"features": {
		"ghcr.io/devcontainers/features/node:1": {
			"version": "lts"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"dbaeumer.vscode-eslint",
				"humao.rest-client"
			]
		}
	},
	"postCreateCommand": "bash scripts/setup-challenge.sh bonus-1-copilot-sdk && cd challenges/bonus-1-copilot-sdk && npm install",
	"remoteUser": "vscode"
}
