{
	"name": "Challenge 2 - Data Science",
	"image": "mcr.microsoft.com/devcontainers/python:3.11",
	"features": {
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"GitHub.copilot",
				"GitHub.copilot-chat",
				"ms-python.python",
				"ms-toolsai.jupyter",
				"ms-python.vscode-pylance"
			]
		}
	},
	"postCreateCommand": "bash scripts/setup-challenge.sh challenge-2-data-science && pip install -r challenges/challenge-2-ml-ai/requirements.txt",
	"remoteUser": "vscode"
}
